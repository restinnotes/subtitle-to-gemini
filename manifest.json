{
  "manifest_version": 3,
  "name": "Subtitle to Gemini",
  "version": "1.0.9",
  "description": "一键复制 YouTube / Bilibili 视频字幕并跳转 Gemini",
  "permissions": [
    "activeTab",
    "storage"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://www.youtube.com/*",
        "https://youtube.com/*",
        "https://www.bilibili.com/video/*",
        "https://bilibili.com/video/*",
        "https://gemini.google.com/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "style.css"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://www.bilibili.com/video/*",
        "https://bilibili.com/video/*"
      ],
      "js": [
        "bili-inject.js"
      ],
      "run_at": "document_idle",
      "world": "MAIN"
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "subtitle-to-gemini-zuoyi@custom.extension",
      "strict_min_version": "142.0",
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      }
    }
  },
  "icons": {
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}